<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{{title}}} · Konto erstellen</title>
    <link rel="stylesheet" href="/css/plugins.min.css">
    <link rel="stylesheet" href="/css/app.min.css">
    <style>
        :root {
            --primary: #1e40af;
            --primary-hover: #1e3a8a;
            --primary-light: #dbeafe;
            --bg: #f3f4f6;
            --card: #ffffff;
            --text: #111827;
            --text-muted: #6b7280;
            --border: #e5e7eb;
            --border-focus: #1e40af;
            --error: #dc2626;
            --error-bg: #fee2e2;
            --success: #059669;
            --success-bg: #d1fae5;
            --warn: #d97706;
            --radius: 8px;
            --shadow: 0 1px 3px rgba(0,0,0,.08), 0 4px 12px rgba(0,0,0,.05);
            --shadow-lg: 0 10px 25px rgba(0,0,0,.1), 0 4px 10px rgba(0,0,0,.05);
        }

        * { box-sizing: border-box; }

        html, body {
            margin: 0;
            padding: 0;
            font: 400 14px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            color: var(--text);
            background: var(--bg);
            min-height: 100%;
        }

        body {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px 16px;
            min-height: 100vh;
        }

        .card {
            width: 100%;
            max-width: 440px;
            background: var(--card);
            border-radius: var(--radius);
            box-shadow: var(--shadow-lg);
            padding: 32px;
        }

        .brand {
            text-align: center;
            margin-bottom: 24px;
        }

        .brand-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 56px;
            height: 56px;
            background: var(--primary-light);
            color: var(--primary);
            border-radius: 12px;
            margin-bottom: 12px;
        }

        .brand-icon svg {
            width: 28px;
            height: 28px;
        }

        .brand h1 {
            margin: 0;
            font-size: 20px;
            font-weight: 600;
            color: var(--text);
        }

        .brand .subtitle {
            margin: 4px 0 0;
            color: var(--text-muted);
            font-size: 14px;
        }

        .field {
            margin-bottom: 16px;
        }

        .field label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: var(--text);
            margin-bottom: 6px;
        }

        .input-wrap {
            position: relative;
        }

        .input,
        input[type="text"].input,
        input[type="email"].input,
        input[type="password"].input {
            width: 100%;
            height: 40px;
            padding: 0 12px;
            font-size: 14px;
            color: var(--text);
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            transition: border-color .15s, box-shadow .15s;
            font-family: inherit;
        }

        .input:focus {
            outline: none;
            border-color: var(--border-focus);
            box-shadow: 0 0 0 3px var(--primary-light);
        }

        .input.has-toggle {
            padding-right: 40px;
        }

        .input.invalid {
            border-color: var(--error);
        }

        .input.invalid:focus {
            box-shadow: 0 0 0 3px var(--error-bg);
        }

        .toggle-pw {
            position: absolute;
            top: 0;
            right: 0;
            width: 40px;
            height: 40px;
            background: none;
            border: 0;
            cursor: pointer;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0;
        }

        .toggle-pw:hover { color: var(--text); }
        .toggle-pw svg { width: 18px; height: 18px; }

        .hint {
            font-size: 12px;
            color: var(--text-muted);
            margin-top: 6px;
            line-height: 1.4;
            min-height: 0;
        }

        .hint.error { color: var(--error); }
        .hint.success { color: var(--success); }

        .strength {
            display: flex;
            gap: 4px;
            margin-top: 8px;
        }

        .strength-bar {
            flex: 1;
            height: 4px;
            background: var(--border);
            border-radius: 2px;
            transition: background .2s;
        }

        .strength.s1 .strength-bar:nth-child(-n+1) { background: var(--error); }
        .strength.s2 .strength-bar:nth-child(-n+2) { background: var(--warn); }
        .strength.s3 .strength-bar:nth-child(-n+3) { background: #ca8a04; }
        .strength.s4 .strength-bar:nth-child(-n+4) { background: var(--success); }

        .captcha-row {
            display: flex;
            gap: 12px;
            align-items: stretch;
        }

        .captcha-img {
            background: #f9fafb;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 4px 8px;
            display: flex;
            align-items: center;
            min-width: 110px;
            min-height: 40px;
            justify-content: center;
        }

        .captcha-img svg {
            display: block;
            max-width: 100%;
            height: 32px;
        }

        .captcha-refresh {
            background: none;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            cursor: pointer;
            color: var(--text-muted);
            width: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .15s;
        }

        .captcha-refresh:hover { background: #f9fafb; color: var(--text); }
        .captcha-refresh svg { width: 18px; height: 18px; }

        .captcha-input {
            flex: 1;
        }

        .privacy-note {
            font-size: 12px;
            color: var(--text-muted);
            margin: 16px 0;
            text-align: center;
        }

        .privacy-note a {
            color: var(--primary);
            text-decoration: none;
        }

        .privacy-note a:hover { text-decoration: underline; }

        .btn {
            width: 100%;
            height: 44px;
            padding: 0 16px;
            font-size: 14px;
            font-weight: 600;
            color: #fff;
            background: var(--primary);
            border: 0;
            border-radius: var(--radius);
            cursor: pointer;
            transition: background .15s;
            font-family: inherit;
        }

        .btn:hover:not(:disabled) { background: var(--primary-hover); }

        .btn:disabled {
            opacity: .55;
            cursor: not-allowed;
        }

        .btn.is-loading {
            color: transparent;
            position: relative;
        }

        .btn.is-loading::after {
            content: "";
            position: absolute;
            top: 50%;
            left: 50%;
            margin: -9px 0 0 -9px;
            width: 18px;
            height: 18px;
            border: 2px solid rgba(255,255,255,.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin .8s linear infinite;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        .footer-link {
            display: block;
            text-align: center;
            margin-top: 16px;
            font-size: 13px;
            color: var(--text-muted);
            text-decoration: none;
        }

        .footer-link:hover { color: var(--primary); }

        .alert {
            padding: 10px 12px;
            border-radius: var(--radius);
            font-size: 13px;
            margin-bottom: 16px;
            display: none;
        }

        .alert.is-visible { display: block; }
        .alert.error { color: var(--error); background: var(--error-bg); }
        .alert.success { color: var(--success); background: var(--success-bg); }

        .modal {
            position: fixed;
            inset: 0;
            background: rgba(17,24,39,.6);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 16px;
            z-index: 100;
        }

        .modal.is-visible { display: flex; }

        .modal-content {
            background: var(--card);
            border-radius: var(--radius);
            padding: 24px;
            max-width: 600px;
            max-height: 80vh;
            overflow-y: auto;
            box-shadow: var(--shadow-lg);
            width: 100%;
        }

        .modal-content h2 {
            margin: 0 0 16px;
            font-size: 18px;
        }

        .modal-content .body {
            color: var(--text);
            font-size: 14px;
            line-height: 1.6;
            margin-bottom: 20px;
        }

        .modal-close {
            background: var(--bg);
            color: var(--text);
            border: 0;
            padding: 10px 20px;
            border-radius: var(--radius);
            cursor: pointer;
            font-weight: 500;
        }

        .modal-close:hover { background: #e5e7eb; }

        .success-state {
            text-align: center;
            padding: 16px 0;
        }

        .success-state .check {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 64px;
            height: 64px;
            background: var(--success-bg);
            color: var(--success);
            border-radius: 50%;
            margin-bottom: 16px;
        }

        .success-state .check svg { width: 32px; height: 32px; }

        .success-state h2 { margin: 0 0 8px; font-size: 20px; }

        .success-state p {
            color: var(--text-muted);
            margin: 0 0 24px;
        }

        .hidden { display: none !important; }
    </style>
</head>
<body>
<main class="card">
    <header class="brand">
        <div class="brand-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 12V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v5a2 2 0 0 1 0 4v3a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-3a2 2 0 0 1 0-4z"></path>
                <path d="M9 7v10"></path>
            </svg>
        </div>
        <h1>OV-EMM Tickets</h1>
        <p class="subtitle">Konto erstellen</p>
    </header>

    <div class="alert" id="globalAlert" role="alert"></div>

    <form id="signupForm" novalidate>
        <div class="field">
            <label for="user-fullname">Vor- und Nachname</label>
            <div class="input-wrap">
                <input id="user-fullname" name="user-fullname" class="input" type="text" autocomplete="name" required />
            </div>
            <div class="hint" id="hint-fullname">Mindestens 5 Zeichen.</div>
        </div>

        <div class="field">
            <label for="user-username">Benutzername</label>
            <div class="input-wrap">
                <input id="user-username" name="user-username" class="input" type="text" autocomplete="username"
                       minlength="3" maxlength="50" pattern="[A-Za-z0-9._-]+" required />
            </div>
            <div class="hint" id="hint-username">3–50 Zeichen, nur Buchstaben, Zahlen, Punkt, Bindestrich oder Unterstrich.</div>
        </div>

        <div class="field">
            <label for="user-email">E-Mail-Adresse</label>
            <div class="input-wrap">
                <input id="user-email" name="user-email" class="input" type="email" autocomplete="email" required />
            </div>
            <div class="hint" id="hint-email"></div>
        </div>

        <div class="field">
            <label for="user-password">Passwort</label>
            <div class="input-wrap">
                <input id="user-password" name="user-password" class="input has-toggle" type="password" autocomplete="new-password" minlength="8" required />
                <button type="button" class="toggle-pw" data-target="user-password" aria-label="Passwort anzeigen">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-icon="eye"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                </button>
            </div>
            <div class="strength" aria-hidden="true">
                <div class="strength-bar"></div>
                <div class="strength-bar"></div>
                <div class="strength-bar"></div>
                <div class="strength-bar"></div>
            </div>
            <div class="hint" id="hint-password">
                Mindestens 8 Zeichen, davon 3 verschiedene Arten:
                Klein-/Großbuchstaben, Zahlen, Sonderzeichen.
            </div>
        </div>

        <div class="field">
            <label for="user-cPassword">Passwort bestätigen</label>
            <div class="input-wrap">
                <input id="user-cPassword" name="user-cPassword" class="input has-toggle" type="password" autocomplete="new-password" minlength="8" required />
                <button type="button" class="toggle-pw" data-target="user-cPassword" aria-label="Passwort anzeigen">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-icon="eye"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                </button>
            </div>
            <div class="hint" id="hint-cPassword"></div>
        </div>

        <div class="field">
            <label for="captcha">Sicherheitscode</label>
            <div class="captcha-row">
                <div class="captcha-img" id="captchaImage" aria-label="Sicherheitscode-Bild"></div>
                <button type="button" class="captcha-refresh" id="captchaRefresh" aria-label="Neuen Sicherheitscode laden" title="Neu laden">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>
                </button>
                <input id="captcha" name="captcha" class="input captcha-input" type="text" autocomplete="off" inputmode="text" required />
            </div>
            <div class="hint" id="hint-captcha">Bitte den Code aus dem Bild abtippen (Groß-/Kleinschreibung beachten).</div>
        </div>

        <p class="privacy-note">
            Mit der Registrierung akzeptierst du die
            <a href="#" id="privacyLink">Datenschutzerklärung</a>.
        </p>

        <button type="submit" class="btn" id="submitBtn">Konto erstellen</button>
    </form>

    <div id="successState" class="success-state hidden">
        <div class="check">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
        </div>
        <h2>Konto erstellt</h2>
        <p>Dein Konto <span id="successEmail"></span> wurde erfolgreich angelegt.</p>
        <a href="/login" class="btn" style="display:inline-flex;align-items:center;justify-content:center;text-decoration:none;">Zur Anmeldung</a>
    </div>

    <a href="/login" class="footer-link" id="loginFooterLink">← Zurück zur Anmeldung</a>
</main>

<div class="modal" id="privacyModal" role="dialog" aria-modal="true" aria-labelledby="privacyTitle">
    <div class="modal-content">
        <h2 id="privacyTitle">Datenschutzerklärung</h2>
        <div class="body" id="privacyBody">
            {{#if data.privacyPolicy}}
                {{{data.privacyPolicy}}}
            {{else}}
                <p>Wir verarbeiten deine Daten (Name, E-Mail-Adresse, von dir eingegebene Ticket-Inhalte) ausschließlich zur Bearbeitung deiner Anfragen im Rahmen dieses Helpdesk-Systems.</p>
                <p>Eine Weitergabe an Dritte findet nicht statt. Die Daten werden auf einem in Deutschland gehosteten Server gespeichert und nach Beendigung der Nutzung auf Anforderung gelöscht.</p>
                <p>Du hast jederzeit das Recht auf Auskunft, Berichtigung und Löschung deiner Daten gemäß DSGVO. Wende dich dazu an den Betreiber des Systems.</p>
                <p style="color:var(--warn);"><strong>Hinweis:</strong> Diese Standard-Datenschutzerklärung ist ein Platzhalter. Bitte ersetze sie im Trudesk-Admin unter <em>Einstellungen → Allgemein → Datenschutzerklärung</em> durch eine auf eure konkrete Nutzung zugeschnittene Fassung.</p>
            {{/if}}
        </div>
        <button type="button" class="modal-close" id="privacyClose">Schließen</button>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/vendor.js"></script>
<script src="/js/truRequire.js"></script>
<script>
    window.truRequire(['jquery', 'snackbar', 'helpers'], function (loadedModules) {
        var $ = loadedModules[0];
        window.Snackbar = loadedModules[1];
        var helpers = loadedModules[2];

        $(document).ready(function () {
            helpers.init();
            loadCaptcha();
            wirePasswordToggles();
            wireValidation();
            wirePrivacyModal();
            wireCaptchaRefresh();
            wireSubmit();
        });

        // ---- Captcha ----
        function loadCaptcha() {
            $('#captchaImage').empty().text('…');
            $.ajax({
                method: 'GET',
                url: '/captcha',
                cache: false,
                success: function (response) {
                    var svg = $(response).find('svg');
                    $('#captchaImage').empty().append(svg);
                    $('#captcha').val('');
                },
                error: function () {
                    $('#captchaImage').empty().text('Fehler');
                    showAlert('Sicherheitscode konnte nicht geladen werden. Bitte Seite neu laden.', 'error');
                }
            });
        }

        function wireCaptchaRefresh() {
            $('#captchaRefresh').on('click', loadCaptcha);
        }

        // ---- Password visibility toggle ----
        function wirePasswordToggles() {
            $('.toggle-pw').on('click', function () {
                var targetId = $(this).data('target');
                var $input = $('#' + targetId);
                var isPassword = $input.attr('type') === 'password';
                $input.attr('type', isPassword ? 'text' : 'password');
                var $icon = $(this).find('svg');
                $icon.attr('data-icon', isPassword ? 'eye-off' : 'eye');
                if (isPassword) {
                    $icon.html('<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line>');
                } else {
                    $icon.html('<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle>');
                }
            });
        }

        // ---- Live validation ----
        function wireValidation() {
            $('#user-fullname').on('blur input', function () {
                var v = ($(this).val() || '').trim();
                var ok = v.length >= 5;
                setFieldState('#user-fullname', '#hint-fullname', ok,
                    ok ? '' : 'Mindestens 5 Zeichen.');
            });

            $('#user-username').on('blur input', function () {
                var v = ($(this).val() || '').trim();
                if (v.length === 0) {
                    setFieldState('#user-username', '#hint-username', null,
                        '3–50 Zeichen, nur Buchstaben, Zahlen, Punkt, Bindestrich oder Unterstrich.');
                    return;
                }
                var validLength = v.length >= 3 && v.length <= 50;
                var validChars = /^[A-Za-z0-9._-]+$/.test(v);
                var ok = validLength && validChars;
                var msg;
                if (!validLength) msg = 'Benutzername muss zwischen 3 und 50 Zeichen lang sein.';
                else if (!validChars) msg = 'Nur Buchstaben, Zahlen, Punkt, Bindestrich oder Unterstrich erlaubt.';
                else msg = 'Benutzername sieht gut aus.';
                setFieldState('#user-username', '#hint-username', ok, msg);
            });

            $('#user-email').on('blur input', function () {
                var v = ($(this).val() || '').trim();
                var ok = isValidEmail(v);
                setFieldState('#user-email', '#hint-email', ok,
                    v.length === 0 ? '' : (ok ? '' : 'Bitte gültige E-Mail-Adresse eingeben.'));
            });

            $('#user-password').on('input', function () {
                var v = $(this).val() || '';
                var s = passwordStrength(v);
                $('.strength').removeClass('s1 s2 s3 s4');
                if (v.length > 0) $('.strength').addClass('s' + s.score);
                var ok = s.meetsMin;
                setFieldState('#user-password', '#hint-password', null, null);
                if (v.length > 0 && !ok) {
                    $('#hint-password').addClass('error').removeClass('success').text(s.message);
                } else {
                    $('#hint-password').removeClass('error success').text('Mindestens 8 Zeichen, davon 3 verschiedene Arten: Klein-/Großbuchstaben, Zahlen, Sonderzeichen.');
                }
                // Re-validate confirm if it has content
                if (($('#user-cPassword').val() || '').length > 0) {
                    $('#user-cPassword').trigger('input');
                }
            });

            $('#user-cPassword').on('input', function () {
                var pw = $('#user-password').val() || '';
                var cpw = $(this).val() || '';
                if (cpw.length === 0) {
                    setFieldState('#user-cPassword', '#hint-cPassword', null, '');
                    return;
                }
                var ok = pw === cpw;
                setFieldState('#user-cPassword', '#hint-cPassword', ok,
                    ok ? 'Passwörter stimmen überein.' : 'Passwörter stimmen nicht überein.');
            });
        }

        function setFieldState(inputSel, hintSel, ok, message) {
            var $input = $(inputSel);
            var $hint = $(hintSel);
            $input.removeClass('invalid');
            $hint.removeClass('error success');
            if (ok === false) {
                $input.addClass('invalid');
                $hint.addClass('error');
            } else if (ok === true) {
                $hint.addClass('success');
            }
            if (message !== null && message !== undefined) {
                $hint.text(message);
            }
        }

        function isValidEmail(v) {
            return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
        }

        function passwordStrength(pw) {
            var diversity = 0;
            if (/[a-z]/.test(pw)) diversity++;
            if (/[A-Z]/.test(pw)) diversity++;
            if (/[0-9]/.test(pw)) diversity++;
            if (/[^A-Za-z0-9]/.test(pw)) diversity++;

            var score = 0;
            var message = '';

            if (pw.length === 0) {
                score = 0;
            } else if (pw.length < 6 || diversity < 2) {
                score = 1;
                message = 'Zu schwach. Mindestens 8 Zeichen mit 3 verschiedenen Zeichenarten erforderlich.';
            } else if (pw.length < 8 || diversity < 3) {
                score = 2;
                message = 'Noch nicht ausreichend. Mindestens 8 Zeichen mit 3 verschiedenen Zeichenarten erforderlich.';
            } else if (diversity < 4) {
                score = 3;
            } else {
                score = 4;
            }

            var meetsMin = pw.length >= 8 && diversity >= 3;
            return { score: score, meetsMin: meetsMin, diversity: diversity, length: pw.length, message: message };
        }

        // ---- Privacy modal ----
        function wirePrivacyModal() {
            $('#privacyLink').on('click', function (e) {
                e.preventDefault();
                $('#privacyModal').addClass('is-visible');
            });
            $('#privacyClose').on('click', function () {
                $('#privacyModal').removeClass('is-visible');
            });
            $('#privacyModal').on('click', function (e) {
                if (e.target === this) $(this).removeClass('is-visible');
            });
        }

        // ---- Submit ----
        function wireSubmit() {
            $('#signupForm').on('submit', function (e) {
                e.preventDefault();
                hideAlert();

                var name = ($('#user-fullname').val() || '').trim();
                var username = ($('#user-username').val() || '').trim();
                var email = ($('#user-email').val() || '').trim();
                var pw = $('#user-password').val() || '';
                var cpw = $('#user-cPassword').val() || '';
                var captcha = ($('#captcha').val() || '').trim();

                // Trigger blur to show field errors
                $('#user-fullname,#user-username,#user-email,#user-password,#user-cPassword').trigger('blur').trigger('input');

                var s = passwordStrength(pw);
                var problems = [];
                if (name.length < 5) problems.push('Name zu kurz');
                if (username.length < 3 || username.length > 50 || !/^[A-Za-z0-9._-]+$/.test(username)) {
                    problems.push('Benutzername ungültig');
                }
                if (!isValidEmail(email)) problems.push('E-Mail ungültig');
                if (!s.meetsMin) problems.push('Passwort entspricht nicht den Anforderungen');
                if (pw !== cpw) problems.push('Passwörter stimmen nicht überein');
                if (captcha.length === 0) problems.push('Sicherheitscode fehlt');

                if (problems.length > 0) {
                    showAlert('Bitte korrigiere die markierten Felder.', 'error');
                    return;
                }

                setLoading(true);

                // Step 1: Check email
                $.ajax({
                    method: 'POST',
                    url: '/api/v1/public/users/checkemail',
                    data: { email: email, captcha: captcha },
                    success: function (data) {
                        if (!data.success) {
                            setLoading(false);
                            showAlert('Ein Fehler ist aufgetreten. Bitte erneut versuchen.', 'error');
                            loadCaptcha();
                            return;
                        }
                        if (data.exist) {
                            setLoading(false);
                            showAlert('Diese E-Mail-Adresse wird bereits verwendet. Möchtest du dich stattdessen <a href="/login">anmelden</a>?', 'error');
                            loadCaptcha();
                            return;
                        }
                        // Step 2: Create account
                        createAccount(name, username, email, pw, captcha);
                    },
                    error: function (xhr) {
                        setLoading(false);
                        showAlert(translateError(xhr), 'error');
                        loadCaptcha();
                    }
                });
            });
        }

        function createAccount(name, username, email, pw, captcha) {
            $.ajax({
                method: 'POST',
                url: '/api/v1/public/account/create',
                data: JSON.stringify({
                    user: { fullname: name, username: username, email: email, password: pw },
                    captcha: captcha
                }),
                contentType: 'application/json',
                success: function (response) {
                    setLoading(false);
                    if (response && response.success) {
                        $('#signupForm').addClass('hidden');
                        $('#loginFooterLink').addClass('hidden');
                        $('#successEmail').text(email);
                        $('#successState').removeClass('hidden');
                    } else {
                        showAlert(translateBackendError((response && response.error) || ''), 'error');
                        loadCaptcha();
                    }
                },
                error: function (xhr) {
                    setLoading(false);
                    showAlert(translateError(xhr), 'error');
                    loadCaptcha();
                }
            });
        }

        function setLoading(loading) {
            var $btn = $('#submitBtn');
            if (loading) {
                $btn.addClass('is-loading').prop('disabled', true);
            } else {
                $btn.removeClass('is-loading').prop('disabled', false);
            }
        }

        function showAlert(html, kind) {
            var $a = $('#globalAlert');
            $a.removeClass('error success').addClass(kind || 'error').addClass('is-visible').html(html);
        }

        function hideAlert() {
            $('#globalAlert').removeClass('is-visible').empty();
        }

        function translateError(xhr) {
            if (xhr && xhr.responseJSON && xhr.responseJSON.error) {
                return translateBackendError(xhr.responseJSON.error);
            }
            return 'Ein unerwarteter Fehler ist aufgetreten. Bitte erneut versuchen.';
        }

        function translateBackendError(err) {
            var map = {
                'Invalid Captcha': 'Sicherheitscode falsch. Bitte erneut versuchen.',
                'Invalid Origin!': 'Ungültiger Anfrage-Ursprung.',
                'Invalid Post Data': 'Ungültige Daten gesendet.',
                'Password does not meet minimum requirements.': 'Passwort entspricht nicht den Sicherheitsanforderungen.',
                'Password does not minimum requirements.': 'Passwort entspricht nicht den Sicherheitsanforderungen.',
                'Username is required.': 'Benutzername ist erforderlich.',
                'Username must be 3–50 characters long.': 'Benutzername muss zwischen 3 und 50 Zeichen lang sein.',
                'Username may only contain letters, digits, dot, dash, or underscore (or be a valid email).': 'Benutzername darf nur Buchstaben, Zahlen, Punkt, Bindestrich oder Unterstrich enthalten.',
                'Username already exists.': 'Dieser Benutzername ist bereits vergeben.',
                'Email already exists.': 'Diese E-Mail-Adresse wird bereits verwendet.'
            };
            if (map[err]) return map[err];
            // Heuristics for common patterns
            if (/username/i.test(err) && /exist/i.test(err)) {
                return 'Dieser Benutzername ist bereits vergeben.';
            }
            if (/email/i.test(err) && /exist/i.test(err)) {
                return 'Diese E-Mail-Adresse wird bereits verwendet.';
            }
            return err || 'Ein unbekannter Fehler ist aufgetreten.';
        }
    });
</script>
</body>
</html>
