# Copy this to .env and replace values for local development
MONGO_INITDB_ROOT_USERNAME=trudesk_admin
MONGO_INITDB_ROOT_PASSWORD=change_me_local_please
MONGO_INITDB_DATABASE=trudesk

# Trudesk app connection (can use same admin user or a separate app user)
TD_MONGODB_SERVER=mongo
TD_MONGODB_PORT=27017
TD_MONGODB_DATABASE=trudesk
# Using the trudesk_app user created by docker/initdb/create-trudesk-user.js
TD_MONGODB_USERNAME=trudesk_app
TD_MONGODB_PASSWORD=app_pass_local

# Optional: use TD_MONGODB_URI to override full connection string
# TD_MONGODB_URI=

# If set to 'true' a lightweight in-memory MongoDB instance will be started and used
# for local development. This avoids needing Docker or a system MongoDB.
TD_USE_INMEM_MONGO=false
